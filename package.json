{
  "name": "auragate",
  "version": "0.1.0",
  "private": true,
  "description": "Discovery & payment marketplace for the agentic economy on Arc — AI agents pay USDC per request via x402 + Circle Gateway, with email/Google login (Circle wallets) and on-chain receipts.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "agent": "tsx agent/run.mts",
    "seller:setup": "tsx scripts/seller-setup.mts",
    "compile": "hardhat compile",
    "deploy:receipts": "hardhat run scripts/deploy_receipts.cjs --network arcTestnet"
  },
  "dependencies": {
    "@circle-fin/user-controlled-wallets": "^10.6.0",
    "@circle-fin/w3s-pw-web-sdk": "^1.1.11",
    "@circle-fin/x402-batching": "^3.2.0",
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/kv": "^3.0.0",
    "@x402/core": "^2.15.0",
    "@x402/evm": "^2.3.0",
    "next": "^16.2.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "viem": "^2.23.7"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "groq-sdk": "^1.2.1",
    "hardhat": "^2.22.17",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
